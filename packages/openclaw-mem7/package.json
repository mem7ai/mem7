{
  "name": "@mem7ai/openclaw-mem7",
  "version": "0.1.2",
  "description": "OpenClaw memory plugin powered by mem7 — LLM fact extraction, graph relations, dedup, and Ebbinghaus forgetting curve.",
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "fmt:check": "prettier --check \"src/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\""
  },
  "openclaw": {
    "type": "memory",
    "name": "mem7",
    "displayName": "Memory (mem7)",
    "minGatewayVersion": "0.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "globals": "^16.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0"
  },
  "dependencies": {
    "@mem7ai/mem7": "^0.3.2",
    "@sinclair/typebox": "^0.34.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.2.0"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mem7ai/mem7",
    "directory": "packages/openclaw-mem7"
  },
  "keywords": [
    "openclaw",
    "memory",
    "plugin",
    "mem7",
    "llm",
    "forgetting-curve",
    "graph-memory"
  ]
}
